APP_NAME=AI Meeting Intelligence System
ENV=dev
# Comma-separated; include both if you open the app as localhost or 127.0.0.1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=aimis

CHROMA_PERSIST_DIR=./storage/chroma
CHROMA_COLLECTION=meeting_transcripts

# LLM (OpenAI-compatible)
LLM_API_KEY=replace_me
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# LLM (Gemini)
# IMPORTANT: do NOT commit real keys; put them only in your local .env
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-1.5-flash

# Whisper
WHISPER_MODEL=base

# Optional: who-spoke-when (WhisperX + pyannote). See requirements-diarization.txt
# ENABLE_SPEAKER_DIARIZATION=false
# HUGGINGFACE_TOKEN=
# WHISPERX_DEVICE=cpu
# WHISPERX_COMPUTE_TYPE=int8
# WHISPERX_BATCH_SIZE=8
# WHISPERX_MODEL=

# Auth (JWT)
JWT_SECRET=replace_me_with_long_random
JWT_ISSUER=aimis
JWT_EXPIRES_MINUTES=10080
