# Same-origin proxy (recommended — avoids CORS "Failed to fetch" in the browser)
NEXT_PUBLIC_API_BASE=/api/backend
# Where Next.js forwards `/api/backend/*` (your FastAPI server)
BACKEND_REWRITE_URL=http://127.0.0.1:8000
# Used when Server Components call the API (must match your `next dev` URL)
NEXT_PUBLIC_APP_ORIGIN=http://127.0.0.1:3000

# Alternative: call FastAPI directly (backend must allow CORS for your UI origin)
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:8000
